{
  "name": "uchovat",
  "license": "Apache-2.0",
  "version": "0.1.0",
  "type": "module",
  "keywords": [
    "feedback",
    "solid",
    "contember"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/uchovat.js"
    }
  },
  "types": "dist/index.d.ts",
  "workspaces": [
    "examples/*"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build && tsc --emitDeclarationOnly",
    "ts:watch": "tsc --watch"
  },
  "dependencies": {
    "html2canvas-pro": "1.5.8",
    "solid-js": "^1.8.15"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^20.17.12",
    "dprint": "^0.51.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.10.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
